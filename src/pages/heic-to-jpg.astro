---
import BaseLayout from '../layouts/BaseLayout.astro';
import FileDropzone from '../components/FileDropzone.astro';
import FaqBlock, { type FaqItem } from '../components/FaqBlock.astro';

const b = import.meta.env.BASE_URL;
const faqs: FaqItem[] = [
  {
    question: 'Are my photos uploaded to a server?',
    answer:
      'No — never. All conversion happens entirely in your browser using JavaScript. Your photos never leave your device. The page will even work if you disconnect from the internet after it loads.',
  },
  {
    question: 'Why can\'t I open or share HEIC photos on Windows or the web?',
    answer:
      'HEIC (High Efficiency Image Container) is Apple\'s default photo format since iOS 11. It compresses better than JPG but is not widely supported outside of Apple devices. Windows, most websites, and most social platforms only accept JPG or PNG — converting to JPG makes your photos universally compatible.',
  },
  {
    question: 'Will converting to JPG reduce the photo quality?',
    answer:
      'This tool converts at 92% JPG quality, which is visually indistinguishable from the original for almost all photos. JPG is a lossy format, so very minor compression artefacts are inherent to the format — but at 92% quality they are imperceptible to the human eye.',
  },
  {
    question: 'Does this work on Windows, Android, and Linux?',
    answer:
      'Yes. The tool runs in any modern browser — Chrome, Firefox, Edge, Safari — on Windows, Mac, Linux, Android, and iOS. No app or plugin installation needed.',
  },
];
---

<BaseLayout
  title="Convert HEIC to JPG — Free, Private, No Upload Required"
  description="Convert HEIC and HEIF photos to JPG instantly in your browser. No upload, no account, no size limits. Works on iPhone photos and any HEIC file."
  canonicalPath="/heic-to-jpg"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-stone-900 mb-3 tracking-tight">
        Convert HEIC to JPG
      </h1>
      <p class="text-stone-500 text-lg leading-relaxed">
        Convert your iPhone HEIC/HEIF photos to JPG entirely in your browser.
        Select multiple files at once — no upload, no waiting, no size limits.
      </p>
    </div>

    <FileDropzone
      id="heic-dropzone"
      accept=".heic,.heif,image/heic,image/heif"
      multiple={true}
      label="Drop your HEIC photos here, or click to select"
      hint="Supports .heic and .heif files (iPhone, iPad, and others)"
    />

    <div id="status-area" class="mt-4 min-h-[1.5rem]" aria-live="polite" aria-atomic="true">
      <div id="status-processing" class="hidden items-center gap-3 text-stone-600 text-sm">
        <svg
          class="animate-spin shrink-0"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M21 12a9 9 0 1 1-6.219-8.56" />
        </svg>
        <span id="status-text">Converting…</span>
      </div>
      <p id="status-error" class="hidden text-red-600 text-sm"></p>
    </div>

    <section id="results-area" class="mt-8 hidden" aria-labelledby="results-heading">
      <div class="flex items-center justify-between mb-4">
        <h2 id="results-heading" class="font-semibold text-stone-900 text-sm">Converted files</h2>
        <button
          id="download-all-btn"
          class="hidden text-sm font-medium text-stone-600 hover:text-stone-900 hover:underline underline-offset-2 transition-colors"
          type="button"
        >
          Download all
        </button>
      </div>
      <ul
        id="results-list"
        class="space-y-2"
        role="list"
        aria-label="Converted image files ready to download"
      >
      </ul>
    </section>

    <FaqBlock items={faqs} />

    <div class="mt-12 pt-8 border-t border-stone-100">
      <p class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-3">More tools</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
        <a href={`${b}remove-photo-metadata`} class="block px-4 py-3 rounded-lg border border-stone-200 hover:border-stone-400 hover:bg-white transition-all group">
          <p class="text-sm font-medium text-stone-800 group-hover:text-stone-900">Remove Metadata</p>
          <p class="text-xs text-stone-500 mt-0.5">Strip GPS from your new JPGs</p>
        </a>
        <a href={`${b}compress-pdf`} class="block px-4 py-3 rounded-lg border border-stone-200 hover:border-stone-400 hover:bg-white transition-all group">
          <p class="text-sm font-medium text-stone-800 group-hover:text-stone-900">Compress PDF</p>
          <p class="text-xs text-stone-500 mt-0.5">Hit any size limit</p>
        </a>
        <a href={`${b}encrypt-file`} class="block px-4 py-3 rounded-lg border border-stone-200 hover:border-stone-400 hover:bg-white transition-all group">
          <p class="text-sm font-medium text-stone-800 group-hover:text-stone-900">Encrypt a File</p>
          <p class="text-xs text-stone-500 mt-0.5">AES-256 password protection</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // heic2any is a browser-only UMD library — dynamic import keeps it out of the SSR pass
  const { default: heic2any } = await import('heic2any');
  import { downloadBlob, downloadAll } from '../lib/download';

  const dropzone = document.getElementById('heic-dropzone')!;
  const statusProcessing = document.getElementById('status-processing')!;
  const statusText = document.getElementById('status-text')!;
  const statusError = document.getElementById('status-error')!;
  const resultsArea = document.getElementById('results-area')!;
  const resultsList = document.getElementById('results-list')!;
  const downloadAllBtn = document.getElementById('download-all-btn')!;

  let convertedItems: { blob: Blob; filename: string }[] = [];

  function setProcessing(active: boolean, message = ''): void {
    if (active) {
      statusText.textContent = message;
      statusProcessing.classList.remove('hidden');
      statusProcessing.classList.add('flex');
    } else {
      statusProcessing.classList.add('hidden');
      statusProcessing.classList.remove('flex');
    }
  }

  function setError(message: string): void {
    statusError.textContent = message;
    statusError.classList.toggle('hidden', !message);
  }

  function buildResultItem(blob: Blob, filename: string): HTMLLIElement {
    const li = document.createElement('li');
    li.className =
      'flex items-center gap-4 rounded-lg border border-stone-200 bg-white px-4 py-3';

    const img = document.createElement('img');
    img.src = URL.createObjectURL(blob);
    img.alt = `Preview of ${filename}`;
    img.className = 'h-12 w-12 rounded-md object-cover shrink-0 border border-stone-200';

    const nameSpan = document.createElement('span');
    nameSpan.className = 'flex-1 text-sm text-stone-700 truncate min-w-0 font-medium';
    nameSpan.textContent = filename;

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className =
      'shrink-0 rounded-md bg-stone-900 px-4 py-1.5 text-sm font-medium text-white hover:bg-stone-800 transition-colors';
    btn.textContent = 'Download';
    btn.setAttribute('aria-label', `Download ${filename}`);
    btn.addEventListener('click', () => downloadBlob(blob, filename));

    li.append(img, nameSpan, btn);
    return li;
  }

  dropzone.addEventListener('filedropzone:change', async (rawEvent) => {
    const { files } = (rawEvent as CustomEvent<{ files: File[] }>).detail;
    if (!files.length) return;

    resultsList.innerHTML = '';
    convertedItems = [];
    resultsArea.classList.add('hidden');
    downloadAllBtn.classList.add('hidden');
    setError('');

    setProcessing(true, `Converting 1 of ${files.length}…`);

    const errors: string[] = [];

    for (let i = 0; i < files.length; i++) {
      const file = files[i];
      setProcessing(true, `Converting ${i + 1} of ${files.length}: ${file.name}`);

      try {
        const result = await heic2any({ blob: file, toType: 'image/jpeg', quality: 0.92 });
        const blob = Array.isArray(result) ? result[0] : result;
        const filename = file.name.replace(/\.(heic|heif)$/i, '.jpg');
        convertedItems.push({ blob, filename });
        resultsList.appendChild(buildResultItem(blob, filename));
      } catch (err) {
        const msg = err instanceof Error ? err.message : 'conversion failed';
        errors.push(`${file.name}: ${msg}`);
      }
    }

    setProcessing(false);

    if (convertedItems.length > 0) {
      resultsArea.classList.remove('hidden');
      if (convertedItems.length > 1) {
        downloadAllBtn.classList.remove('hidden');
      }
    }

    if (errors.length > 0) {
      setError(
        errors.length === 1
          ? `Could not convert ${errors[0]}`
          : `${errors.length} files failed: ${errors.join(' · ')}`,
      );
    }
  });

  downloadAllBtn.addEventListener('click', () => {
    downloadAll(convertedItems);
  });
</script>
