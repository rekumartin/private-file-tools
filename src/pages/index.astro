---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import FaqBlock, { type FaqItem } from '../components/FaqBlock.astro';

const b = import.meta.env.BASE_URL;

const iconImage = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`;
const iconEyeOff = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`;
const iconMinimize = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="10" y1="14" x2="3" y2="21"/><line x1="21" y1="3" x2="14" y2="10"/></svg>`;
const iconLock = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`;

const tools = [
  {
    icon: iconImage,
    title: 'HEIC to JPG',
    description: 'Share your iPhone photos anywhere — converted to JPG locally, no upload required.',
    href: `${b}heic-to-jpg`,
    screenshot: `${b}screenshots/heic-to-jpg.png`,
  },
  {
    icon: iconEyeOff,
    title: 'Remove Photo Metadata',
    description: 'Strip GPS location and camera info before sharing photos online.',
    href: `${b}remove-photo-metadata`,
    screenshot: `${b}screenshots/remove-photo-metadata.png`,
  },
  {
    icon: iconMinimize,
    title: 'Compress PDF',
    description: 'Hit email attachment limits without uploading to a third-party converter.',
    href: `${b}compress-pdf`,
    screenshot: `${b}screenshots/compress-pdf.png`,
  },
  {
    icon: iconLock,
    title: 'Encrypt a File',
    description: 'Lock sensitive files with AES-256 before sharing or storing them.',
    href: `${b}encrypt-file`,
    screenshot: `${b}screenshots/encrypt-file.png`,
  },
];

const faqs: FaqItem[] = [
  {
    question: 'Are my files uploaded to a server?',
    answer: 'No — never. All processing runs inside your browser tab. There is no server to upload to. You can verify this yourself: open DevTools, go to the Network tab, disconnect your internet, and use a tool. It still works.',
  },
  {
    question: 'Does it work offline?',
    answer: 'Yes. Once the page has loaded, disconnect from the internet and try any tool. Everything still works because no network connection is involved in the processing.',
  },
  {
    question: 'Does it work on mobile?',
    answer: 'Yes. All tools work in any modern browser — Chrome, Safari, Firefox — on iPhone, Android, Windows, Mac, and Linux.',
  },
  {
    question: 'Is the source code public?',
    answer: 'Yes. You can read every line that runs in your browser on GitHub. There are no hidden network calls.',
  },
  {
    question: 'Why is it free?',
    answer: 'It\'s a personal project. I built these tools because I kept needing to convert or clean files without wanting to upload them to a random website.',
  },
];
---

<BaseLayout
  title="FileHaven — Private File Conversion Without Uploads"
  description="Convert, compress, and clean files entirely in your browser. No uploads, no servers, no account. Works offline. Open source."
  canonicalPath="/"
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-20 pb-12">
    <h1 class="text-5xl sm:text-6xl font-bold text-stone-900 leading-[1.08] tracking-tight mb-5">
      Stop uploading<br class="hidden sm:block" />
      sensitive files to<br class="hidden sm:block" />
      random websites.
    </h1>
    <p class="text-lg text-stone-500 max-w-lg leading-relaxed mb-8">
      FileHaven converts, compresses, and cleans files entirely in your
      browser. Your files never touch our servers — because there are no servers.
    </p>

    <!-- Trust bar -->
    <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-stone-500">
      {[
        'No uploads — ever',
        'Works offline',
        'Open source',
        'No account',
        'No tracking',
      ].map((item) => (
        <span class="flex items-center gap-1.5">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-stone-400 shrink-0" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          {item}
        </span>
      ))}
    </div>
  </section>

  <!-- Credibility metrics -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-12" aria-label="Stats">
    <div class="flex flex-wrap gap-x-10 gap-y-4 py-6 border-y border-stone-100">
      {[
        { stat: '4', label: 'tools' },
        { stat: '0', label: 'files ever uploaded' },
        { stat: '100%', label: 'runs in your browser' },
        { stat: '∞', label: 'file size limit' },
      ].map(({ stat, label }) => (
        <div class="flex items-baseline gap-2">
          <span class="text-2xl font-bold text-stone-900 tabular-nums">{stat}</span>
          <span class="text-sm text-stone-500">{label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Tools grid -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20" aria-labelledby="tools-heading">
    <p id="tools-heading" class="text-xs font-medium tracking-widest uppercase text-stone-400 mb-4">Tools</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {tools.map((tool) => <ToolCard {...tool} />)}
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20 border-t border-stone-100 pt-14">
    <p class="text-xs font-medium tracking-widest uppercase text-stone-400 mb-8">How it works</p>
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-0 max-w-2xl">
      <div class="text-center sm:text-left">
        <p class="text-sm font-semibold text-stone-900">Your file</p>
        <p class="text-xs text-stone-400 mt-0.5">stays on your device</p>
      </div>
      <div class="hidden sm:flex items-center gap-1 mx-6 text-stone-300 flex-1">
        <div class="h-px flex-1 bg-stone-200"></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>
      <div class="sm:hidden text-stone-300 text-lg leading-none pl-1">↓</div>
      <div class="rounded-lg border border-stone-200 bg-white px-5 py-3 text-center">
        <p class="text-sm font-semibold text-stone-900">Your browser</p>
        <p class="text-xs text-stone-400 mt-0.5">processes it locally</p>
      </div>
      <div class="hidden sm:flex items-center gap-1 mx-6 text-stone-300 flex-1">
        <div class="h-px flex-1 bg-stone-200"></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>
      <div class="sm:hidden text-stone-300 text-lg leading-none pl-1">↓</div>
      <div class="text-center sm:text-left">
        <p class="text-sm font-semibold text-stone-900">Your result</p>
        <p class="text-xs text-stone-400 mt-0.5">downloads instantly</p>
      </div>
    </div>
    <p class="text-xs text-stone-400 mt-6 leading-relaxed max-w-lg">
      No server involved at any step. No upload. No account. No waiting.<br />
      <span class="text-stone-400">Powered by <strong class="font-medium text-stone-500">WebAssembly</strong>, the <strong class="font-medium text-stone-500">Web Crypto API</strong>, the <strong class="font-medium text-stone-500">Canvas API</strong>, and the browser <strong class="font-medium text-stone-500">File API</strong> — the same technologies used in secure messaging and banking apps.</span>
    </p>
  </section>

  <!-- Verify it yourself -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20 border-t border-stone-100 pt-14">
    <p class="text-xs font-medium tracking-widest uppercase text-stone-400 mb-6">Verify it yourself</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-10 max-w-2xl">
      <div>
        <p class="text-sm text-stone-600 leading-relaxed mb-4">
          We can say all we want about privacy. Here's how to check it for yourself — no trust required.
        </p>
        <ol class="space-y-2 text-sm text-stone-600">
          <li class="flex items-start gap-2.5">
            <span class="shrink-0 w-5 h-5 rounded-full bg-stone-100 text-stone-500 text-xs flex items-center justify-center font-medium mt-0.5">1</span>
            Open DevTools <span class="text-stone-400 text-xs">(F12 or right-click → Inspect)</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="shrink-0 w-5 h-5 rounded-full bg-stone-100 text-stone-500 text-xs flex items-center justify-center font-medium mt-0.5">2</span>
            Click the <strong class="font-medium text-stone-700">Network</strong> tab
          </li>
          <li class="flex items-start gap-2.5">
            <span class="shrink-0 w-5 h-5 rounded-full bg-stone-100 text-stone-500 text-xs flex items-center justify-center font-medium mt-0.5">3</span>
            Disconnect from the internet
          </li>
          <li class="flex items-start gap-2.5">
            <span class="shrink-0 w-5 h-5 rounded-full bg-stone-100 text-stone-500 text-xs flex items-center justify-center font-medium mt-0.5">4</span>
            Drop a file into any tool on this page
          </li>
        </ol>
        <p class="text-sm text-stone-500 mt-4 leading-relaxed">
          You'll see zero network requests — and the tool still works. That's the only proof that matters.
        </p>
      </div>
      <div>
        <p class="text-xs font-medium tracking-widest uppercase text-stone-400 mb-4">Or check the source</p>
        <p class="text-sm text-stone-500 leading-relaxed mb-4">
          Every line that runs in your browser is public. Read it, audit it, self-host it.
        </p>
        <a
          href="https://github.com/rekumartin/filehaven"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-stone-300 bg-white px-4 py-2 text-sm font-medium text-stone-800 hover:border-stone-500 hover:bg-stone-50 transition-all"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View source on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20 border-t border-stone-100 pt-14">
    <p class="text-xs font-medium tracking-widest uppercase text-stone-400 mb-8">vs. typical online converters</p>
    <div class="overflow-x-auto">
      <table class="w-full max-w-2xl text-sm border-collapse">
        <thead>
          <tr class="border-b border-stone-200">
            <th class="text-left py-3 pr-8 font-medium text-stone-500 w-48"></th>
            <th class="text-left py-3 pr-8 font-semibold text-stone-900">FileHaven</th>
            <th class="text-left py-3 font-medium text-stone-400">Typical converter</th>
          </tr>
        </thead>
        <tbody>
          {[
            ['Upload required', 'Never', 'Every time'],
            ['Works offline', 'Yes', 'No'],
            ['Account required', 'No', 'Sometimes'],
            ['Source code public', 'Yes', 'Rarely'],
            ['Ads or tracking', 'None', 'Usually'],
            ['Cost', 'Free', 'Free or paid'],
          ].map(([feature, ours, theirs]) => (
            <tr class="border-b border-stone-100">
              <td class="py-3 pr-8 text-stone-500">{feature}</td>
              <td class="py-3 pr-8 font-medium text-stone-900">{ours}</td>
              <td class="py-3 text-stone-400">{theirs}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Personal note -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20 border-t border-stone-100 pt-14">
    <p class="text-xs font-medium tracking-widest uppercase text-stone-400 mb-6">About</p>
    <div class="max-w-lg">
      <p class="text-stone-600 leading-relaxed text-sm">
        I built these tools because I kept needing to convert or clean files and didn't want
        to upload them to a random website. Most online converters are probably fine — but
        for sensitive documents, tax forms, and private photos, the upload itself is the risk.
      </p>
      <p class="text-stone-600 leading-relaxed text-sm mt-4">
        These tools run entirely in your browser. I use them myself.
      </p>
      <p class="mt-5">
        <a
          href={`${b}about`}
          class="text-sm text-stone-700 underline underline-offset-2 hover:text-stone-900"
        >
          More about this project →
        </a>
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20 border-t border-stone-100 pt-14">
    <FaqBlock items={faqs} heading="Common questions" />
  </section>

  <!-- Roadmap -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-28 border-t border-stone-100 pt-14">
    <p class="text-xs font-medium tracking-widest uppercase text-stone-400 mb-2">What's coming</p>
    <p class="text-sm text-stone-500 mb-6">The project is under active development. Planned tools:</p>
    <div class="space-y-3 max-w-sm">
      {[
        'Merge PDFs — combine multiple files locally',
        'Convert images — PNG, WebP, AVIF and more',
        'Resize and compress images without quality loss',
        'Extract or reorder pages from a PDF',
      ].map((item) => (
        <div class="flex items-start gap-3 text-sm text-stone-500">
          <div class="mt-0.5 w-3.5 h-3.5 rounded border border-stone-300 shrink-0" aria-hidden="true"></div>
          {item}
        </div>
      ))}
    </div>
    <p class="text-xs text-stone-400 mt-5">
      Suggest a tool or follow progress on{' '}
      <a href="https://github.com/rekumartin/filehaven" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-stone-600">
        GitHub
      </a>.
    </p>
  </section>
</BaseLayout>
