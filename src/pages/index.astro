---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';

const b = import.meta.env.BASE_URL;

const iconImage = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`;

const iconEyeOff = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`;

const iconMinimize = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="10" y1="14" x2="3" y2="21"/><line x1="21" y1="3" x2="14" y2="10"/></svg>`;

const iconLock = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`;

const tools = [
  {
    icon: iconImage,
    title: 'HEIC to JPG',
    description:
      'Convert iPhone HEIC/HEIF photos to JPG — no upload, no account, no size limits.',
    href: `${b}heic-to-jpg`,
  },
  {
    icon: iconEyeOff,
    title: 'Remove Photo Metadata',
    description:
      'Strip GPS location, camera model, and all hidden EXIF data from photos before sharing.',
    href: `${b}remove-photo-metadata`,
  },
  {
    icon: iconMinimize,
    title: 'Compress PDF',
    description:
      'Shrink a PDF to under 1 MB, 2 MB, or any custom limit. Lossless or maximum compression.',
    href: `${b}compress-pdf`,
  },
  {
    icon: iconLock,
    title: 'Encrypt a File',
    description:
      'Password-protect any file with AES-256-GCM. No external libraries, nothing uploaded.',
    href: `${b}encrypt-file`,
  },
];

const trustPoints = [
  {
    heading: 'Files never leave your device',
    body: 'Processing runs in your browser tab using JavaScript. Nothing is sent over the network — there is no server to send it to.',
  },
  {
    heading: 'Verify it yourself',
    body: 'Once this page loads, disconnect from the internet and try a tool. Everything still works. That\'s the only proof that matters.',
  },
  {
    heading: 'No account, no tracking',
    body: 'No sign-up, no cookies, no analytics by default. We can\'t see your files even if we wanted to.',
  },
  {
    heading: 'Open source',
    body: 'Every line that runs in your browser is public.',
    link: { href: 'https://github.com/rekumartin/private-file-tools', label: 'View source on GitHub →' },
  },
];
---

<BaseLayout
  title="PrivateFileTools — Free, Private, Browser-Based File Tools"
  description="Convert and process files 100% in your browser. No uploads, no servers, no data collection. Fast, private, and free."
  canonicalPath="/"
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-20 pb-16">
    <h1 class="text-5xl sm:text-6xl font-bold text-stone-900 leading-[1.08] tracking-tight mb-5">
      File tools that<br class="hidden sm:block" />
      respect your privacy.
    </h1>
    <p class="text-lg text-stone-500 max-w-lg leading-relaxed mb-3">
      Every tool runs entirely in your browser. Your files never touch
      our servers — because there are no servers.
    </p>
    <p class="text-sm font-medium text-stone-700 mb-8">
      Once the page loads, disconnect from the internet and try — it still works.
    </p>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-stone-400">
      <span>No uploads</span>
      <span aria-hidden="true">·</span>
      <span>Works offline</span>
      <span aria-hidden="true">·</span>
      <span>Always free</span>
    </div>
  </section>

  <!-- Why it's private -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20 border-t border-stone-100 pt-14" aria-labelledby="privacy-heading">
    <p id="privacy-heading" class="text-xs font-medium tracking-widest uppercase text-stone-400 mb-8">
      Why it's private
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-8">
      {trustPoints.map(({ heading, body, link }) => (
        <div>
          <p class="font-semibold text-stone-900 text-sm mb-2">{heading}</p>
          <p class="text-sm text-stone-500 leading-relaxed">
            {body}
            {link && (
              <>
                {' '}
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-stone-700 underline underline-offset-2 hover:text-stone-900 transition-colors"
                >
                  {link.label}
                </a>
              </>
            )}
          </p>
        </div>
      ))}
    </div>
  </section>

  <!-- Tools grid -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-28 border-t border-stone-100 pt-14" aria-labelledby="tools-heading">
    <p
      id="tools-heading"
      class="text-xs font-medium tracking-widest uppercase text-stone-400 mb-4"
    >
      Tools
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {tools.map((tool) => <ToolCard {...tool} />)}
    </div>
  </section>
</BaseLayout>
