---
import BaseLayout from '../layouts/BaseLayout.astro';
import FileDropzone from '../components/FileDropzone.astro';
import FaqBlock, { type FaqItem } from '../components/FaqBlock.astro';

const b = import.meta.env.BASE_URL;
const faqs: FaqItem[] = [
  {
    question: 'Is my file or password sent to a server?',
    answer:
      'No — never. All encryption and decryption happens inside your browser tab using the browser\'s built-in Web Crypto API. Your file and password never leave your device. The page works entirely offline once loaded.',
  },
  {
    question: 'What encryption algorithm is used?',
    answer:
      'AES-256-GCM — the same algorithm used by TLS, government systems, and password managers. The key is derived from your password using PBKDF2 with SHA-256 and 600,000 iterations, which makes brute-force attacks extremely slow. Each file is encrypted with a unique random salt and IV, so encrypting the same file twice produces different outputs.',
  },
  {
    question: 'What happens if I lose the password?',
    answer:
      'The file is permanently unrecoverable. We have no password reset, no backdoor, and no way to help — that is the nature of strong encryption. Keep your password in a password manager or written down somewhere secure before encrypting important files.',
  },
  {
    question: 'Can I encrypt any type or size of file?',
    answer:
      'Yes — any file type is supported. The size limit is determined by your browser\'s available memory, typically several gigabytes on a modern device. Very large files (>1 GB) may be slow because the entire file is read into memory.',
  },
  {
    question: 'Is the original filename protected?',
    answer:
      'Yes. The original filename is encrypted inside the payload along with the file contents. The only visible metadata is the .enc extension on the output file. An attacker who obtains the .enc file learns nothing about the original filename, file type, or contents without the password.',
  },
];
---

<BaseLayout
  title="Encrypt a File — AES-256 In-Browser File Encryption"
  description="Encrypt any file with a password using AES-256-GCM — entirely in your browser. No upload, no account. Your password and file never leave your device."
  canonicalPath="/encrypt-file"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-stone-900 mb-3 tracking-tight">
        Encrypt a File
      </h1>
      <p class="text-stone-500 text-lg leading-relaxed">
        Password-protect any file with AES-256-GCM encryption — entirely in your browser,
        using no external libraries. Your password and your file never leave this tab.
      </p>
    </div>

    <!-- Crypto details -->
    <div class="mb-6 flex flex-wrap gap-2">
      {
        [
          'AES-256-GCM',
          'PBKDF2 · 600 000 iterations',
          'Random salt + IV per file',
          'Web Crypto API — no libraries',
        ].map((chip) => (
          <span class="inline-flex items-center rounded-full border border-stone-200 bg-stone-100 px-3 py-1 text-xs font-medium text-stone-600">
            {chip}
          </span>
        ))
      }
    </div>

    <!-- Mode selector -->
    <fieldset class="mb-6">
      <legend class="text-sm font-semibold text-stone-700 mb-3">Mode</legend>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <label
          id="card-encrypt"
          class="mode-card flex items-start gap-3 rounded-lg border-2 border-stone-900 bg-stone-900/5 p-4 cursor-pointer transition-colors"
        >
          <input type="radio" name="crypto-mode" value="encrypt" checked class="sr-only" />
          <div class="mt-0.5 h-4 w-4 shrink-0 rounded-full border-2 border-stone-900 flex items-center justify-center mode-radio">
            <div class="h-2 w-2 rounded-full bg-stone-900 mode-dot"></div>
          </div>
          <div>
            <p class="font-semibold text-stone-900 text-sm">Encrypt</p>
            <p class="text-xs text-stone-500 mt-1 leading-relaxed">
              Choose a file and a password → get a <code class="font-mono text-stone-700">.enc</code>
              file you can share or store safely.
            </p>
          </div>
        </label>

        <label
          id="card-decrypt"
          class="mode-card flex items-start gap-3 rounded-lg border-2 border-stone-200 p-4 cursor-pointer hover:border-stone-300 transition-colors"
        >
          <input type="radio" name="crypto-mode" value="decrypt" class="sr-only" />
          <div class="mt-0.5 h-4 w-4 shrink-0 rounded-full border-2 border-stone-300 flex items-center justify-center mode-radio">
            <div class="h-2 w-2 rounded-full bg-transparent mode-dot"></div>
          </div>
          <div>
            <p class="font-semibold text-stone-900 text-sm">Decrypt</p>
            <p class="text-xs text-stone-500 mt-1 leading-relaxed">
              Choose a <code class="font-mono text-stone-700">.enc</code> file and the
              original password → recover the original file.
            </p>
          </div>
        </label>
      </div>
    </fieldset>

    <!-- Password input -->
    <div class="mb-6">
      <label for="password-input" class="block text-sm font-semibold text-stone-700 mb-2">
        Password
      </label>
      <div class="relative">
        <input
          id="password-input"
          type="password"
          autocomplete="off"
          spellcheck="false"
          placeholder="Enter a strong password"
          class="w-full rounded-lg border border-stone-300 px-4 py-2.5 pr-12 text-sm text-stone-900 placeholder-stone-400 focus:border-stone-700 focus:ring-1 focus:ring-stone-700 outline-none transition-colors bg-white"
          aria-describedby="password-strength-label"
        />
        <button
          id="password-toggle"
          type="button"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-stone-400 hover:text-stone-600 transition-colors"
          aria-label="Show password"
          aria-pressed="false"
        >
          <svg id="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
          </svg>
          <svg id="eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
            <line x1="1" y1="1" x2="23" y2="23"/>
          </svg>
        </button>
      </div>

      <!-- Strength indicator (encrypt mode only) -->
      <div id="strength-section" class="mt-2">
        <div class="flex gap-1 mb-1" aria-hidden="true">
          <div class="h-1 flex-1 rounded-full bg-stone-200 strength-seg"></div>
          <div class="h-1 flex-1 rounded-full bg-stone-200 strength-seg"></div>
          <div class="h-1 flex-1 rounded-full bg-stone-200 strength-seg"></div>
          <div class="h-1 flex-1 rounded-full bg-stone-200 strength-seg"></div>
        </div>
        <p id="password-strength-label" class="text-xs text-stone-400 strength-label" aria-live="polite"></p>
      </div>

      <!-- Password loss warning -->
      <div id="password-warning" class="mt-3 flex items-start gap-2 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
        <svg class="shrink-0 mt-0.5 text-amber-600" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <p class="text-xs text-amber-800 leading-relaxed">
          <strong>If you forget this password, the file is permanently unrecoverable.</strong>
          There is no reset. Save it somewhere safe before encrypting.
        </p>
      </div>
    </div>

    <!-- File dropzones -->
    <div id="encrypt-zone">
      <FileDropzone
        id="encrypt-dropzone"
        accept="*/*"
        multiple={false}
        label="Drop any file to encrypt, or click to select"
        hint="Any file type, any size (limited by available browser memory)"
      />
    </div>
    <div id="decrypt-zone" class="hidden">
      <FileDropzone
        id="decrypt-dropzone"
        accept=".enc,application/octet-stream"
        multiple={false}
        label="Drop your .enc file here, or click to select"
        hint="Only files encrypted by this tool (.enc)"
      />
    </div>

    <!-- Status -->
    <div
      id="status-area"
      class="mt-4 min-h-[1.5rem]"
      aria-live="polite"
      aria-atomic="true"
    >
      <div id="status-processing" class="hidden items-center gap-3 text-stone-600 text-sm">
        <svg class="animate-spin shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M21 12a9 9 0 1 1-6.219-8.56" />
        </svg>
        <span id="status-text">Processing…</span>
      </div>
      <p id="status-error" class="hidden text-red-600 text-sm"></p>
    </div>

    <!-- Action button -->
    <div class="mt-4">
      <button
        id="action-btn"
        type="button"
        class="hidden rounded-lg bg-stone-900 px-6 py-2.5 text-sm font-semibold text-white hover:bg-stone-800 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        aria-label="Encrypt the selected file"
      >
        Encrypt file
      </button>
    </div>

    <!-- Result -->
    <section id="results-area" class="mt-8 hidden" aria-labelledby="result-heading">
      <h2 id="result-heading" class="font-semibold text-stone-900 text-sm mb-4">Result</h2>
      <div id="result-card"></div>
    </section>

    <FaqBlock items={faqs} />

    <div class="mt-12 pt-8 border-t border-stone-100">
      <p class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-3">More tools</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
        <a href={`${b}heic-to-jpg`} class="block px-4 py-3 rounded-lg border border-stone-200 hover:border-stone-400 hover:bg-white transition-all group">
          <p class="text-sm font-medium text-stone-800 group-hover:text-stone-900">HEIC to JPG</p>
          <p class="text-xs text-stone-500 mt-0.5">Convert iPhone photos</p>
        </a>
        <a href={`${b}remove-photo-metadata`} class="block px-4 py-3 rounded-lg border border-stone-200 hover:border-stone-400 hover:bg-white transition-all group">
          <p class="text-sm font-medium text-stone-800 group-hover:text-stone-900">Remove Metadata</p>
          <p class="text-xs text-stone-500 mt-0.5">Strip GPS and EXIF</p>
        </a>
        <a href={`${b}compress-pdf`} class="block px-4 py-3 rounded-lg border border-stone-200 hover:border-stone-400 hover:bg-white transition-all group">
          <p class="text-sm font-medium text-stone-800 group-hover:text-stone-900">Compress PDF</p>
          <p class="text-xs text-stone-500 mt-0.5">Hit any size limit</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { encryptFile, decryptFile } from '../lib/fileCrypto';
  import { downloadBlob } from '../lib/download';

  const modeInputs = document.querySelectorAll<HTMLInputElement>('input[name="crypto-mode"]');
  const modeCards = document.querySelectorAll<HTMLElement>('.mode-card');
  const encryptZone = document.getElementById('encrypt-zone')!;
  const decryptZone = document.getElementById('decrypt-zone')!;
  const encryptDropzone = document.getElementById('encrypt-dropzone')!;
  const decryptDropzone = document.getElementById('decrypt-dropzone')!;
  const passwordInput = document.getElementById('password-input') as HTMLInputElement;
  const passwordToggle = document.getElementById('password-toggle')!;
  const eyeOpen = document.getElementById('eye-open')!;
  const eyeOff = document.getElementById('eye-off')!;
  const strengthSection = document.getElementById('strength-section')!;
  const strengthSegs = document.querySelectorAll<HTMLElement>('.strength-seg');
  const strengthLabel = document.querySelector<HTMLElement>('.strength-label')!;
  const passwordWarning = document.getElementById('password-warning')!;
  const statusProcessing = document.getElementById('status-processing')!;
  const statusText = document.getElementById('status-text')!;
  const statusError = document.getElementById('status-error')!;
  const actionBtn = document.getElementById('action-btn') as HTMLButtonElement;
  const resultsArea = document.getElementById('results-area')!;
  const resultCard = document.getElementById('result-card')!;

  type CryptoMode = 'encrypt' | 'decrypt';
  let mode: CryptoMode = 'encrypt';
  let currentFile: File | null = null;

  /* ── Password strength ─────────────────────────────────────────────────────── */
  const STRENGTH = [
    { min: 0, label: '', segs: 0, color: '' },
    { min: 1, label: 'Too short — use at least 8 characters', segs: 1, color: 'bg-red-500' },
    { min: 8, label: 'Weak — add length and variety', segs: 2, color: 'bg-amber-400' },
    { min: 12, label: 'Good', segs: 3, color: 'bg-yellow-400' },
    { min: 16, label: 'Strong', segs: 4, color: 'bg-green-500' },
  ];

  function scorePassword(pw: string): number {
    if (!pw) return 0;
    if (pw.length < 8) return 1;
    let s = 1;
    if (pw.length >= 12) s++;
    if (pw.length >= 16) s++;
    if (/[A-Z]/.test(pw) && /[a-z]/.test(pw)) s += 0.5;
    if (/\d/.test(pw)) s += 0.5;
    if (/[^A-Za-z0-9]/.test(pw)) s += 0.5;
    return Math.min(4, Math.floor(s));
  }

  function updateStrength(pw: string): void {
    const score = scorePassword(pw);
    const tier = STRENGTH[score];
    strengthLabel.textContent = tier.label;
    strengthSegs.forEach((seg, i) => {
      seg.className = `h-1 flex-1 rounded-full ${i < tier.segs ? tier.color : 'bg-stone-200'}`;
    });
  }

  passwordInput.addEventListener('input', () => {
    if (mode === 'encrypt') updateStrength(passwordInput.value);
    updateActionBtn();
  });

  /* ── Show / hide password ──────────────────────────────────────────────────── */
  passwordToggle.addEventListener('click', () => {
    const isHidden = passwordInput.type === 'password';
    passwordInput.type = isHidden ? 'text' : 'password';
    eyeOpen.classList.toggle('hidden', isHidden);
    eyeOff.classList.toggle('hidden', !isHidden);
    passwordToggle.setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
    passwordToggle.setAttribute('aria-pressed', isHidden ? 'true' : 'false');
  });

  /* ── Mode switching ────────────────────────────────────────────────────────── */
  function syncModeUI(): void {
    modeCards.forEach((card) => {
      const input = card.querySelector<HTMLInputElement>('input')!;
      const active = input.checked;
      card.classList.toggle('border-stone-900', active);
      card.classList.toggle('bg-stone-900/5', active);
      card.classList.toggle('border-stone-200', !active);
      card.querySelector<HTMLElement>('.mode-radio')!.classList.toggle('border-stone-900', active);
      card.querySelector<HTMLElement>('.mode-radio')!.classList.toggle('border-stone-300', !active);
      card.querySelector<HTMLElement>('.mode-dot')!.classList.toggle('bg-stone-900', active);
      card.querySelector<HTMLElement>('.mode-dot')!.classList.toggle('bg-transparent', !active);
    });

    const isEncrypt = mode === 'encrypt';
    encryptZone.classList.toggle('hidden', !isEncrypt);
    decryptZone.classList.toggle('hidden', isEncrypt);
    strengthSection.classList.toggle('hidden', !isEncrypt);
    passwordWarning.classList.toggle('hidden', !isEncrypt);

    actionBtn.textContent = isEncrypt ? 'Encrypt file' : 'Decrypt file';
    actionBtn.setAttribute('aria-label', isEncrypt ? 'Encrypt the selected file' : 'Decrypt the selected file');

    passwordInput.placeholder = isEncrypt ? 'Enter a strong password' : 'Enter the decryption password';
    passwordInput.type = 'password';
    eyeOpen.classList.remove('hidden');
    eyeOff.classList.add('hidden');
    passwordToggle.setAttribute('aria-pressed', 'false');

    currentFile = null;
    updateActionBtn();
    resetResults();
  }

  modeInputs.forEach((input) => {
    input.addEventListener('change', () => {
      mode = input.value as CryptoMode;
      syncModeUI();
    });
  });

  /* ── File selection ────────────────────────────────────────────────────────── */
  function onFilesSelected(files: File[]): void {
    currentFile = files[0] ?? null;
    updateActionBtn();
    resetResults();
  }

  encryptDropzone.addEventListener('filedropzone:change', (e) => {
    onFilesSelected((e as CustomEvent<{ files: File[] }>).detail.files);
  });
  decryptDropzone.addEventListener('filedropzone:change', (e) => {
    onFilesSelected((e as CustomEvent<{ files: File[] }>).detail.files);
  });

  /* ── Action button visibility ──────────────────────────────────────────────── */
  function updateActionBtn(): void {
    const hasFile = currentFile !== null;
    actionBtn.classList.toggle('hidden', !hasFile);
  }

  /* ── Status helpers ────────────────────────────────────────────────────────── */
  function setProcessing(active: boolean, message = ''): void {
    statusText.textContent = message;
    statusProcessing.classList.toggle('hidden', !active);
    statusProcessing.classList.toggle('flex', active);
    actionBtn.disabled = active;
  }

  function setError(msg: string): void {
    statusError.textContent = msg;
    statusError.classList.toggle('hidden', !msg);
  }

  function resetResults(): void {
    resultsArea.classList.add('hidden');
    resultCard.innerHTML = '';
    setError('');
    setProcessing(false);
  }

  /* ── Result card ───────────────────────────────────────────────────────────── */
  function fmtBytes(n: number): string {
    if (n < 1024) return `${n} B`;
    if (n < 1_048_576) return `${(n / 1024).toFixed(1)} KB`;
    return `${(n / 1_048_576).toFixed(2)} MB`;
  }

  function showResult(blob: Blob, filename: string, note?: string): void {
    resultsArea.classList.remove('hidden');
    resultCard.innerHTML = '';

    const card = document.createElement('div');
    card.className = 'rounded-lg border border-stone-200 bg-white overflow-hidden';

    const row = document.createElement('div');
    row.className = 'flex items-center gap-4 px-5 py-4';

    const info = document.createElement('div');
    info.className = 'flex-1 min-w-0';

    const nameEl = document.createElement('p');
    nameEl.className = 'font-medium text-stone-900 text-sm truncate';
    nameEl.textContent = filename;

    const sizeEl = document.createElement('p');
    sizeEl.className = 'text-xs text-stone-500 mt-0.5';
    sizeEl.textContent = fmtBytes(blob.size);

    info.append(nameEl, sizeEl);

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'shrink-0 rounded-md bg-stone-900 px-4 py-1.5 text-sm font-medium text-white hover:bg-stone-800 transition-colors';
    btn.textContent = 'Download';
    btn.setAttribute('aria-label', `Download ${filename}`);
    btn.addEventListener('click', () => downloadBlob(blob, filename));

    row.append(info, btn);
    card.appendChild(row);

    if (note) {
      const noteEl = document.createElement('p');
      noteEl.className = 'px-5 pb-3 text-xs text-stone-500 border-t border-stone-100 pt-3';
      noteEl.textContent = note;
      card.appendChild(noteEl);
    }

    resultCard.appendChild(card);
  }

  /* ── Main processing ───────────────────────────────────────────────────────── */
  actionBtn.addEventListener('click', async () => {
    if (!currentFile) return;
    const password = passwordInput.value;
    if (!password) {
      setError('Please enter a password.');
      passwordInput.focus();
      return;
    }

    resetResults();
    setProcessing(true, mode === 'encrypt' ? 'Encrypting…' : 'Decrypting…');

    try {
      if (mode === 'encrypt') {
        const result = await encryptFile(currentFile, password);
        setProcessing(false);
        showResult(
          result.blob,
          result.filename,
          'AES-256-GCM encrypted. Keep your password safe — without it this file cannot be decrypted.',
        );
      } else {
        const result = await decryptFile(currentFile, password);
        setProcessing(false);
        showResult(result.blob, result.filename, `Original filename recovered: ${result.filename}`);
      }
    } catch (err) {
      setProcessing(false);
      setError(err instanceof Error ? err.message : 'An unexpected error occurred.');
    }
  });
</script>
