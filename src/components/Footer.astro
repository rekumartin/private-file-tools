---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-100 bg-gray-50 mt-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
    <p>&copy; {year} PrivateFileTools. All processing is local, in your browser.</p>
    <nav aria-label="Footer navigation">
      <ul class="flex gap-6 list-none p-0 m-0">
        <li>
          <a href={`${import.meta.env.BASE_URL}about`} class="hover:text-gray-900 transition-colors">About</a>
        </li>
        <li>
          <a href={`${import.meta.env.BASE_URL}privacy`} class="hover:text-gray-900 transition-colors">Privacy</a>
        </li>
      </ul>
    </nav>
  </div>
</footer>
