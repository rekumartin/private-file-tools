---
import PrivacyBadge from './PrivacyBadge.astro';
---

<header class="sticky top-0 z-50 border-b border-gray-100 bg-white/95 backdrop-blur-sm">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-4">
    <a
      href={import.meta.env.BASE_URL}
      class="text-lg font-semibold text-gray-900 hover:text-blue-600 transition-colors"
      aria-label="PrivateFileTools — home"
    >
      PrivateFileTools
    </a>
    <PrivacyBadge size="sm" />
  </div>
</header>
