---
interface Props {
  size?: 'sm' | 'md';
}
const { size = 'md' } = Astro.props;
const iconSize = size === 'sm' ? 11 : 13;
---

<div
  class:list={[
    'inline-flex items-center gap-1.5 rounded-full bg-stone-100 text-stone-500 font-medium border border-stone-200',
    size === 'sm' ? 'px-2.5 py-0.5 text-xs' : 'px-3 py-1 text-sm',
  ]}
  role="status"
  aria-label="Privacy guarantee"
>
  <svg
    aria-hidden="true"
    class="shrink-0"
    width={iconSize}
    height={iconSize}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
  </svg>
  Nothing is uploaded
</div>
